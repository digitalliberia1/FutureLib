# Copy this file to backend/.env and fill in your values

MONGODB_URL=mongodb://mongo:27017
MONGODB_DB_NAME=futurelib
REDIS_URL=redis://redis:6379

SECRET_KEY=CHANGE_THIS_TO_LONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

OPENAI_API_KEY=
STRIPE_SECRET_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=futurelib-assets

# ─── Open edX Integration ────────────────────────────────────────────────────
# Tutor local dev defaults (change to production domains for K8s deployment)
OPENEDX_LMS_URL=http://local.edly.io
OPENEDX_CMS_URL=http://studio.local.edly.io
OPENEDX_DISCOVERY_URL=http://discovery.local.edly.io

# Create via: tutor local do createclient --name futurelib --client-id futurelib-client
OPENEDX_CLIENT_ID=futurelib-client
OPENEDX_CLIENT_SECRET=CHANGE_THIS_OPENEDX_SECRET

# Platform settings
OPENEDX_PLATFORM_NAME=FutureLib
OPENEDX_AUTO_PROVISION=true

# LTI (optional — for embedded course player)
OPENEDX_LTI_SECRET=CHANGE_THIS_LTI_SECRET

# Frontend env (add to frontend/.env)
# REACT_APP_OPENEDX_LMS_URL=http://local.edly.io
