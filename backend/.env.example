APP_NAME=FutureLib
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

MONGODB_URL=mongodb://mongo:27017
MONGODB_DB_NAME=futurelib

REDIS_URL=redis://redis:6379

SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

ALLOWED_ORIGINS=["http://localhost:3000","https://futurelib.gov.lr"]

SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key
EMAIL_FROM=noreply@futurelib.gov.lr
EMAIL_FROM_NAME=FutureLib

S3_BUCKET=futurelib-assets
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret

OPENAI_API_KEY=your_openai_key

STRIPE_SECRET_KEY=your_stripe_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

RATE_LIMIT_PER_MINUTE=60
